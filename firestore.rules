rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Secure the core user collections
    // Allow authenticated users to read/write data. 
    // This is required for the dashboard and profile pages to work.
    match /Dealers/{dealerId} {
      allow read, write: if request.auth != null;
      
      // Allow sub-collections like 'transfers' to be accessed as well
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /Retailers/{retailerId} {
      allow read, write: if request.auth != null;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Secure the codes generated by admins
    match /codes/{codeId} {
      allow read, write: if request.auth != null;
    }

    // Secure your other system collections
    match /Customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    match /EmiDetails/{emiId} {
      allow read, write: if request.auth != null;
    }

    match /Notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    // Catch-all: require authentication for any other data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}