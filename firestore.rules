rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to query the Dealers collection to find their email for login.
    // This is required for the mobile number login flow to work.
    // This rule is not secure for production if you have sensitive data in the Dealers collection.
    match /Dealers/{dealerId} {
      allow read: if true;
      allow write: if request.auth != null; // Only authenticated users can write
    }

    // For all other documents in the database, require the user to be authenticated.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}